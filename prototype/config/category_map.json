    "Expenses:Charity": {
      "summary_bucket": "tax_adjacent.cash_charitable_contributions",
      "summary_key": "cash_charity",
      "expected_source_sign": "negative",
      "allowed_tax_hints": ["Schedule A cash charity"]
    },
    "Liabilities:Federal Tax:Estimated Payments": {
      "summary_bucket": "tax_adjacent.federal_estimated_payments",
      "summary_key": "federal_estimated_payments",
      "expected_source_sign": "negative",
      "allowed_tax_hints": ["Form 1040 estimated payments"]
